# Application
APP_NAME=Synapse Chat
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=True

# Server
HOST=0.0.0.0
PORT=8000

# AI Provider Configuration
# Options: "claude" | "openai" | "ollama"
AI_PROVIDER=claude

# Claude API (Anthropic)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI API (optionnel)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4-turbo-preview

# Ollama (LLM local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2
# Autres modèles: mistral, codellama, neural-chat, etc.

# RAG Configuration
ENABLE_RAG=True
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
CHROMA_PERSIST_DIR=./data/chroma
MAX_CHUNKS_TO_RETRIEVE=5

# Database
DATABASE_URL=postgresql+asyncpg://synapsechat:synapsechat123@localhost:5432/synapsechat_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=0

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL=3600

# Security
SECRET_KEY=your-secret-key-change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS
CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

# File Upload
MAX_UPLOAD_SIZE=10485760  # 10MB
ALLOWED_EXTENSIONS=[".pdf", ".txt", ".docx", ".md"]

# Conversation
MAX_CONVERSATION_HISTORY=20
MAX_MESSAGE_LENGTH=4000
